---
import '@/styles/globals.css'
import Logo from '@/components/Logo';
import { Button } from '@/components/ui/button';
import UrgencyBar from '@/components/UrgencyBar';
import ContactModal from '@/components/ContactModal';
import Navbar from '@/components/Navbar';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark scroll-smooth overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="AxiomSystemsCo — Custom Bot & Automation Agency. We build ticket snipers, web scrapers, WhatsApp bots, and enterprise automation systems for modern businesses." />
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://axiomsystemsco.com/" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="AxiomSystemsCo — Custom Bot & Automation Agency. We build ticket snipers, web scrapers, WhatsApp bots, and enterprise automation systems for modern businesses." />
    <meta property="og:image" content="https://axiomsystemsco.com/og-image.png" />
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://axiomsystemsco.com/" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content="AxiomSystemsCo — Custom Bot & Automation Agency. We build ticket snipers, web scrapers, WhatsApp bots, and enterprise automation systems for modern businesses." />
    <meta property="twitter:image" content="https://axiomsystemsco.com/og-image.png" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <!-- Preload Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body class="bg-background text-foreground antialiased min-h-screen selection:bg-white/20 overflow-x-hidden">
    
    {/* UrgencyBar Removed for cleaner look */}

    <!-- Sophisticated Background Mesh -->
    <div class="fixed inset-0 -z-10 bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(120,119,198,0.15),rgba(255,255,255,0))]"></div>
    <div class="fixed inset-0 -z-10 bg-[url('/grid-pattern.svg')] opacity-[0.03] [mask-image:linear-gradient(180deg,white,transparent)]"></div>

    <!-- Navigation (Linear Style) -->
    <Navbar client:load />

    <ContactModal client:load />

    <slot />
    
    <script>
      import Lenis from 'lenis';

      const lenis = new Lenis({
        duration: 1.2,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      });

      function raf(time: number) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }

      requestAnimationFrame(raf);
    </script>
  </body>
</html>
