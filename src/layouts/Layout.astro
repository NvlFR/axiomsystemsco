---
import '@/styles/globals.css'
import { Button } from '@/components/ui/button';
import UrgencyBar from '@/components/UrgencyBar';
import ContactModal from '@/components/ContactModal';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="AxiomSystemsCo - Custom Bot Automation All System. Automate your business with AI and custom bots." />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <!-- Preload Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body class="bg-background text-foreground antialiased min-h-screen selection:bg-white/20">
    
    {/* UrgencyBar Removed for cleaner look */}

    <!-- Sophisticated Background Mesh -->
    <div class="fixed inset-0 -z-10 bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(120,119,198,0.15),rgba(255,255,255,0))]"></div>
    <div class="fixed inset-0 -z-10 bg-[url('/grid-pattern.svg')] opacity-[0.03] [mask-image:linear-gradient(180deg,white,transparent)]"></div>

    <!-- Navigation (Linear Style) -->
    <nav class="fixed top-0 w-full z-50 border-b border-white/[0.08] bg-background/60 backdrop-blur-xl supports-[backdrop-filter]:bg-background/40">
      <div class="max-w-[1240px] mx-auto px-6 h-[64px] flex items-center justify-between">
        
        {/* Logo Area */}
        <a href="/" class="flex items-center gap-3 decoration-0 group">
          <div class="w-5 h-5 rounded-[4px] bg-white flex items-center justify-center text-black font-bold text-[10px] group-hover:scale-90 transition-transform">
            A
          </div>
          <span class="text-[14px] font-semibold text-white tracking-tight">AxiomSystemsCo</span>
        </a>

        {/* Center Links */}
        <div class="hidden md:flex gap-8 items-center absolute left-1/2 -translate-x-1/2">
          <a href="#services" class="text-[14px] text-linear-text-secondary hover:text-white transition-colors duration-200">Services</a>
          <a href="#process" class="text-[14px] text-linear-text-secondary hover:text-white transition-colors duration-200">Process</a>
          <a href="#casestudies" class="text-[14px] text-linear-text-secondary hover:text-white transition-colors duration-200">Case Studies</a>
          <a href="#about" class="text-[14px] text-linear-text-secondary hover:text-white transition-colors duration-200">About</a>
        </div>

        <div class="flex items-center gap-4">
          <Button 
            client:load
            onClick={() => window.dispatchEvent(new CustomEvent('open-contact-modal'))}
            size="sm" 
            className="h-[32px] px-3.5 bg-white text-black hover:bg-[#e0e0e0] border-0 font-medium transition-all rounded-[6px] text-[13px] shadow-sm cursor-pointer"
          >
            Start Project
          </Button>
        </div>
      </div>
    </nav>

    <ContactModal client:load />

    <slot />
    
    <script>
      import Lenis from 'lenis';

      const lenis = new Lenis({
        duration: 1.2,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      });

      function raf(time: number) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }

      requestAnimationFrame(raf);
    </script>
  </body>
</html>
