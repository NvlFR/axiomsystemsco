---
import Layout from '@/layouts/Layout.astro';
import Hero from '@/components/Hero';
import Services from '@/components/Services';
import Process from '@/components/Process';
import FAQ from '@/components/FAQ';
import OrderForm from '@/components/OrderForm';
import FloatingCTA from '@/components/FloatingCTA';
import LiveFormDemo from '@/components/LiveFormDemo';
import DataExtractionDemo from '@/components/DataExtractionDemo';
import WorkflowDemo from '@/components/WorkflowDemo';
import { Command } from 'lucide-react';
---

<Layout title="AxiomSystemsCo - Custom Bot Development Agency">
  <main>
    <Hero client:load />
    
    <LiveFormDemo client:visible />
    <DataExtractionDemo client:visible />
    <WorkflowDemo client:visible />

    <Process client:visible />
    <Services client:visible />
    <FAQ client:visible />
    <OrderForm client:visible />
    <FloatingCTA client:load />
  </main>
  
  <footer class="py-20 border-t border-white/[0.08] bg-[#08090a]">
    <div class="max-w-[1240px] mx-auto px-6 grid grid-cols-2 md:grid-cols-6 gap-10">
      
      <div class="col-span-2 md:col-span-2 space-y-4">
        <a href="/" class="flex items-center gap-2 decoration-0">
          <div class="w-5 h-5 rounded-[4px] bg-white flex items-center justify-center text-black font-bold text-[10px]">
            A
          </div>
          <span class="text-[14px] font-semibold text-white tracking-tight">AxiomSystemsCo</span>
        </a>
        <p class="text-sm text-linear-text-secondary max-w-xs">
          Automating the impossible for high-performance teams worldwide.
        </p>
      </div>

      <div class="space-y-4">
        <h4 class="text-[14px] font-medium text-white">Offerings</h4>
        <ul class="space-y-3 text-[14px] text-linear-text-secondary">
          <li><a href="#" class="hover:text-white transition-colors">Custom Bots</a></li>
          <li><a href="#" class="hover:text-white transition-colors">Consulting</a></li>
          <li><a href="#" class="hover:text-white transition-colors">Scraping</a></li>
          <li><a href="#" class="hover:text-white transition-colors">Maintenance</a></li>
        </ul>
      </div>

      <div class="space-y-4">
        <h4 class="text-[14px] font-medium text-white">Company</h4>
        <ul class="space-y-3 text-[14px] text-linear-text-secondary">
          <li><a href="#" class="hover:text-white transition-colors">About</a></li>
          <li><a href="#" class="hover:text-white transition-colors">Blog</a></li>
          <li><a href="#" class="hover:text-white transition-colors">Careers</a></li>
          <li><a href="#" class="hover:text-white transition-colors">Legal</a></li>
        </ul>
      </div>

       <div class="space-y-4">
        <h4 class="text-[14px] font-medium text-white">Connect</h4>
        <ul class="space-y-3 text-[14px] text-linear-text-secondary">
          <li><a href="#" class="hover:text-white transition-colors">Twitter</a></li>
          <li><a href="#" class="hover:text-white transition-colors">GitHub</a></li>
          <li><a href="#" class="hover:text-white transition-colors">Discord</a></li>
        </ul>
      </div>

    </div>
    
    <div class="max-w-[1240px] mx-auto px-6 mt-20 pt-8 border-t border-white/[0.08] flex items-center justify-between">
       <p class="text-xs text-linear-text-secondary">&copy; {new Date().getFullYear()} AxiomSystemsCo. All rights reserved.</p>
       <div class="flex gap-4">
         <div class="w-2 h-2 rounded-full bg-green-500"></div>
         <span class="text-xs text-linear-text-secondary">All Systems Normal</span>
       </div>
    </div>
  </footer>
</Layout>
